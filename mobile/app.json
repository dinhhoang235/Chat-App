{
  "expo": {
    "name": "DiskordMes",
    "slug": "diskordmes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.mobile",
      "notification": {
        "icon": "./assets/images/icon.png"
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.diskordmes.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "RECORD_AUDIO",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED"
      ],
      "notification": {
        "icon": "./assets/images/notification-icon.png",
        "color": "#ffffff"
      }
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#ffffff",
          "sounds": ["./assets/sounds/notification.mp3"],
          "defaultChannel": "chat"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Cho phép DiskordMes truy cập camera."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Cho phép DiskordMes truy cập thư viện ảnh của bạn để lưu mã QR."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Cho phép DiskordMes truy cập microphone để ghi âm."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Cho phép DiskordMes truy cập microphone để nhập bằng giọng nói.",
          "speechRecognitionPermission": "Cho phép DiskordMes nhận diện giọng nói để chuyển thành văn bản.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8a1c985d-6bc4-4690-af04-8427cde087f3"
      }
    }
  }
}
