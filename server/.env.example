PORT=3000

# MySQL Configuration
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=chat_app
MYSQL_USER=chatuser
MYSQL_PASSWORD=chatpass
MYSQL_PORT=3306

# Prisma Database URL (format: mysql://user:password@host:port/database)
DATABASE_URL="mysql://chatuser:chatpass@localhost:3306/chat_app"

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Server Configuration
NODE_ENV=development

# JWT Secret
JWT_SECRET=your_jwt_secret_here
